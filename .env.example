# Runtime secrets configured in Netlify for Production and Deploy Previews.
ADMIN_PASSWORD=replace-with-a-strong-shared-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Only needed locally by `npm run backup` for a manual Blob snapshot.
NETLIFY_SITE_ID=your-netlify-site-id
NETLIFY_AUTH_TOKEN=your-netlify-personal-access-token
